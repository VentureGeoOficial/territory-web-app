rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function statsUnchangedUsers() {
      return request.resource.data.xp == resource.data.xp
        && request.resource.data.totalAreaM2 == resource.data.totalAreaM2
        && request.resource.data.territoriesCount == resource.data.territoriesCount;
    }

    function optionalDistanceUnchanged() {
      return (!(resource.data.keys().hasAny(['totalDistanceM']))
            && !(request.resource.data.keys().hasAny(['totalDistanceM'])))
        || (request.resource.data.totalDistanceM == resource.data.totalDistanceM);
    }

    function optionalDurationUnchanged() {
      return (!(resource.data.keys().hasAny(['totalDurationSeconds']))
            && !(request.resource.data.keys().hasAny(['totalDurationSeconds'])))
        || (request.resource.data.totalDurationSeconds == resource.data.totalDurationSeconds);
    }

    /** Chaves permitidas em users no primeiro create (cadastro completo ou perfil mínimo). */
    function userCreateKeysAllowed() {
      return request.resource.data.keys().hasOnly([
        'displayName', 'nomeCompleto', 'email', 'username', 'dataNascimento', 'sexo',
        'peso', 'altura', 'notificationPreferences', 'legalAcceptance', 'color',
        'totalAreaM2', 'territoriesCount', 'xp', 'createdAt', 'updatedAt'
      ])
      || request.resource.data.keys().hasOnly([
        'displayName', 'email', 'color', 'totalAreaM2', 'territoriesCount', 'xp',
        'notificationPreferences', 'createdAt', 'updatedAt'
      ]);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
        && userCreateKeysAllowed()
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.color is string
        && request.resource.data.xp == 0
        && request.resource.data.totalAreaM2 == 0
        && request.resource.data.territoriesCount == 0;

      allow update: if isOwner(userId)
        && statsUnchangedUsers()
        && optionalDistanceUnchanged()
        && optionalDurationUnchanged()
        && request.resource.data.email == resource.data.email
        && request.resource.data.username == resource.data.username;

      allow delete: if false;
    }

    match /publicProfiles/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
        && request.resource.data.displayName is string
        && request.resource.data.color is string
        && request.resource.data.xp == 0
        && request.resource.data.totalAreaM2 == 0
        && request.resource.data.territoriesCount == 0
        && (!request.resource.data.keys().hasAny(['username'])
            || request.resource.data.username is string);

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['displayName', 'username', 'updatedAt'])
        && request.resource.data.xp == resource.data.xp
        && request.resource.data.totalAreaM2 == resource.data.totalAreaM2
        && request.resource.data.territoriesCount == resource.data.territoriesCount
        && request.resource.data.color == resource.data.color
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if false;
    }

    match /usersPrivate/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /usernames/{slug} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['uid', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.createdAt is number
        && slug.matches('^[a-z0-9_]{3,30}$')
        && !exists(/databases/$(database)/documents/usernames/$(slug));
      allow update, delete: if false;
    }

    match /territories/{territoryId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /runs/{runId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(['fromUserId', 'toUserId', 'status', 'createdAt'])
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.fromUserId != request.resource.data.toUserId
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is number;

      allow update: if isSignedIn()
        && resource.data.status == 'pending'
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly(['fromUserId', 'toUserId', 'status', 'createdAt'])
        && (
          (request.auth.uid == resource.data.toUserId
            && request.resource.data.status in ['accepted', 'rejected'])
          || (request.auth.uid == resource.data.fromUserId
            && request.resource.data.status == 'cancelled')
        );

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
