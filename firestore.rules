rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Perfil público para ranking e exibição social
    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Dados privados sensíveis do usuário
    match /usersPrivate/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Índice único: doc ID = slug; corpo mínimo { uid, createdAt }
    match /usernames/{slug} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usernames/$(slug));
      allow update, delete: if false;
    }

    match /territories/{territoryId} {
      allow read: if true;

      function isValidTerritoryPayload() {
        let data = request.resource.data;
        return
          // Owner consistente
          data.userId == request.auth.uid
          // Área razoável (0 < areaM2 <= 10 km²)
          && data.areaM2 is number
          && data.areaM2 > 0
          && data.areaM2 <= 10_000_000
          // Status conhecido
          && data.status in ['active', 'disputed', 'protected', 'expired']
          // PolygonJson com tamanho limitado
          && data.polygonJson is string
          && data.polygonJson.size() <= 200000;
      }

      allow create: if request.auth != null
        && isValidTerritoryPayload();

      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid
        && isValidTerritoryPayload();
    }

    match /runs/{runId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.territoryId is string
        && request.resource.data.startedAt is number
        && request.resource.data.endedAt is number
        && request.resource.data.distanceMeters is number
        && request.resource.data.durationSeconds is number
        && request.resource.data.areaM2 is number
        && request.resource.data.areaM2 > 0
        && request.resource.data.areaM2 <= 10000000
        && request.resource.data.xpGained is number
        && request.resource.data.routeJson is string
        && request.resource.data.routeJson.size() <= 400000;
      allow update, delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending';
      allow update: if request.auth != null
        && (resource.data.toUserId == request.auth.uid
            || resource.data.fromUserId == request.auth.uid);
      allow delete: if false;
    }
  }
}
