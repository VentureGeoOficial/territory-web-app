# =============================================================================
# TerritoryRun Web — variáveis de ambiente
# =============================================================================
# Em produção (Vercel), defina cada variável no painel:
#   Project Settings -> Environment Variables
#
# Em desenvolvimento local, copie este ficheiro para .env.local (ignorado pelo
# Git) e preencha os valores. NUNCA faça commit de .env.local.
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase — chaves PÚBLICAS (cliente)
# -----------------------------------------------------------------------------
# Estas variáveis são incorporadas no bundle JavaScript que vai para o browser.
# Não são "segredos": são identificadores do projeto Firebase. Restrinja o uso
# delas via App Check, domínios autorizados e Firestore Security Rules.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Opcionais — preencha se o seu projeto usar estes serviços:
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# Firebase Admin — credencial PRIVADA (servidor)
# -----------------------------------------------------------------------------
# Conteúdo completo do JSON da Service Account (Firebase Console ->
# Configurações do projeto -> Contas de Serviço -> Gerar nova chave privada).
#
# Como colar no Vercel:
#   - Cole o JSON inteiro como uma única linha (ou use a private_key com \n
#     escapados literalmente — o código aceita ambos os formatos).
#   - Marque APENAS os ambientes Server (Production / Preview / Development);
#     NUNCA prefixe com NEXT_PUBLIC_, sob risco crítico de exposição.

FIREBASE_SERVICE_ACCOUNT_JSON=
